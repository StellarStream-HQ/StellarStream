{
  "name": "stellarstream-backend",
  "version": "1.0.0",
  "description": "Backend service for StellarStream - Stellar network payment streaming indexer",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run --reporter verbose",
    "test:watch": "vitest"
  },
  "keywords": [
    "stellar",
    "blockchain",
    "streaming",
    "payments"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.4.1",
    "@stellar/stellar-sdk": "^12.3.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "prisma": "^7.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
